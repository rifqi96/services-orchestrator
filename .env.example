# =============================================================================
# .env.example — host-specific settings & secrets for services-orchestrator
# -----------------------------------------------------------------------------
# Copy to .env (the CLI's `init`/`env` commands manage this for you).
# .env is gitignored. Per-service routing lives in services.yml, NOT here.
# =============================================================================

# production | staging | local  (mirrors defaults.environment in services.yml;
# this value wins for runtime scripts). Controls certbot staging vs. real.
ENVIRONMENT=production

# Email for Let's Encrypt registration.
CERTBOT_EMAIL=you@example.com

# 1 = use Let's Encrypt staging endpoint (no rate limits, untrusted certs).
# Automatically forced to 1 unless ENVIRONMENT is production or staging.
CERTBOT_STAGING=1

# Optional: override the compose project name (defaults to "sorch").
# COMPOSE_PROJECT_NAME=sorch
